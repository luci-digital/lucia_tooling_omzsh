# ---------------------------------------------------------------------------
# Aifam Mesh MCP (Iris) - environment configuration
# Copy to `.env` and adjust. All values have sane defaults; nothing is required.
# ---------------------------------------------------------------------------
#
# 1Password injection workflow (RECOMMENDED for API keys):
#   op inject -i .env.example -o .env
#
# Manual workflow:
#   cp .env.example .env
#   # Then replace op:// references with actual values

# Transport: how AI runtimes connect to this server.
#   stdio - one client over stdin/stdout (Claude Desktop, CLIs, MCPB)
#   http  - many runtimes over Streamable HTTP (browsers, remote agents, k8s)
AIFAM_TRANSPORT=stdio
AIFAM_HTTP_HOST=127.0.0.1
AIFAM_HTTP_PORT=8788
AIFAM_HTTP_PATH=/mcp

# --- exo distributed inference cluster (MLX / tinygrad) ---------------------
# exo exposes an OpenAI- and Claude-compatible API and auto-discovers nodes.
EXO_BASE_URL=http://localhost:52415
EXO_DEFAULT_MODEL=llama-3.2-3b
EXO_REQUEST_TIMEOUT_MS=600000

# --- Home Assistant Matter Server -------------------------------------------
# WebSocket controller for Matter devices (lights, plugs, sensors, locks...).
MATTER_ENABLED=true
MATTER_WS_URL=ws://localhost:5580/ws
MATTER_COMMAND_TIMEOUT_MS=30000

# --- Cloud backends (let agents fan out to cloud runtimes) ------------------
# Which backend agents use when none is specified: mesh | anthropic | openai
AIFAM_DEFAULT_BACKEND=mesh
# Anthropic (Claude) via the official SDK. Leave key unset to disable.
# Using 1Password references (inject with: op inject -i .env.example -o .env)
ANTHROPIC_API_KEY=op://Lucia-AI-Secrets/Anthropic-Claude-API-Key/credential
# ANTHROPIC_BASE_URL=
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=4096
# OpenAI-compatible runtime (also covers Groq/OpenRouter/Together/vLLM via base URL).
# Using 1Password references (inject with: op inject -i .env.example -o .env)
# Note: Create OpenAI API key item if needed, or leave blank to disable
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# --- Luciverse / Aifam agent mesh -------------------------------------------
# Minimum coherence required to route a tiered agent invocation (0..1).
LUCIVERSE_COHERENCE_MIN=0.7
# Optional path to a JSON file that overrides/extends the built-in agent roster.
# AIFAM_AGENTS_FILE=./agents.json

# debug | info | warn | error
LOG_LEVEL=info
