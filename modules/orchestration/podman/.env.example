# LuciDigital sovereign stack — environment template (LOCAL profile).
# Copy to `.env` in this directory and fill in real values. NEVER commit `.env`.
#
# 1Password injection workflow (RECOMMENDED):
#   op inject -i .env.example -o .env
#
# Manual workflow:
#   cp .env.example .env        # local
#   cp .env.staging.example .env
#   cp .env.production.example .env
#   # Then replace 1Password references with actual values
#
# Secrets management: for production prefer a Nix-compatible secrets manager
# (sops-nix or agenix) or the 1Password switchboard. This .env is the
# boring fallback; keep it out of git.

# ── Ingress (Caddy) ──────────────────────────────────────────────────────────
LUCIVERSE_ADMIN_EMAIL=admin@lucidigital.local

# ── Coder CDE — REQUIRED secrets (compose fails fast if unset) ───────────────
# Generate strong values, e.g. `openssl rand -hex 32`.
# Using 1Password references (inject with: op inject -i .env.example -o .env)
CODER_DB_PASSWORD=op://LuciVerse-PAC/Coder Local/db_password
CODER_PSK=op://LuciVerse-PAC/Coder Local/psk

# ── Coder URLs (local) ───────────────────────────────────────────────────────
CODER_ACCESS_URL=http://coder.lucidigital.io
CODER_WILDCARD_ACCESS_URL=*.coder.lucidigital.io

# ── Gogs OAuth (optional — leave blank to disable Coder↔Gogs SSO) ────────────
# Using 1Password references (inject with: op inject -i .env.example -o .env)
GOGS_OAUTH_CLIENT_ID=op://LuciVerse-CORE/Gogs OAuth Local/client_id
GOGS_OAUTH_CLIENT_SECRET=op://LuciVerse-CORE/Gogs OAuth Local/client_secret

# ── A-Tune UI SPA build output mounted by Caddy (optional override) ──────────
# ATUNE_UI_DIST=../../../A-Tune-UI/dist/spa

# ── OpenDeepWiki model config (defaults to local Ollama, airgap-first) ───────
ODW_CHAT_MODEL=llama3.2
ODW_ANALYSIS_MODEL=llama3.2
ODW_ENDPOINT=http://host.containers.internal:11434/v1
ODW_PROVIDER=OpenAI
# For local Ollama, keep as "ollama". For cloud providers, uncomment and use 1Password reference
ODW_API_KEY=ollama

# ── Workspace paths (optional — defaults to relative paths) ──────────────────
# These can be set if your workspace layout differs from the default structure
# LUCIA_ORCHESTRATOR_PATH=../../../luciverse-core-orchestrator
# LUCIA_COMPOSITOR_PATH=~/lucia_compositor
# LUA_SUBSTRATE_PATH=~/lua-substrate
