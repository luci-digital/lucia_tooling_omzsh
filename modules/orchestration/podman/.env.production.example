# LuciDigital sovereign stack — PRODUCTION profile template.
# Copy to `.env` and inject real secrets from sops-nix / agenix / op://.
# NEVER commit `.env` or real production secrets.

LUCIVERSE_ADMIN_EMAIL=ops@lucidigital.io

# REQUIRED — MUST come from a secrets manager in production, never plaintext git.
CODER_DB_PASSWORD=__INJECT_FROM_SECRETS_MANAGER__
CODER_PSK=__INJECT_FROM_SECRETS_MANAGER__

CODER_ACCESS_URL=https://coder.lucidigital.io
CODER_WILDCARD_ACCESS_URL=*.coder.lucidigital.io

# Production OAuth between Coder and Gogs (inject secret).
GOGS_OAUTH_CLIENT_ID=__INJECT_FROM_SECRETS_MANAGER__
GOGS_OAUTH_CLIENT_SECRET=__INJECT_FROM_SECRETS_MANAGER__

# Point at the production inference endpoint (or keep local Ollama for airgap).
ODW_CHAT_MODEL=llama3.2
ODW_ANALYSIS_MODEL=llama3.2
ODW_ENDPOINT=http://host.containers.internal:11434/v1
ODW_PROVIDER=OpenAI
ODW_API_KEY=__INJECT_FROM_SECRETS_MANAGER__

# ── Workspace paths (optional — defaults to relative paths) ──────────────────
# These can be set if your workspace layout differs from the default structure
# LUCIA_ORCHESTRATOR_PATH=../../../luciverse-core-orchestrator
# LUCIA_COMPOSITOR_PATH=~/lucia_compositor
# LUA_SUBSTRATE_PATH=~/lua-substrate
