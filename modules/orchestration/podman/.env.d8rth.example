IPFS_GATEWAY_PORT=8080
IPFS_SCION_TRANSPORT=scion/5-528,[2602:F674:0001:0528::10]/udp/4001/scion-quic

# Homestar (IPVM)
HOMESTAR_PORT=3030
HOMESTAR_METRICS_PORT=9090

# Ray (Distributed Compute)
RAY_HEAD_PORT=6378
RAY_DASHBOARD_PORT=8265
RAY_OBJECT_STORE_MEMORY=1000000000  # 1GB
RAY_NUM_CPUS=4

# Build Agent
BUILD_AGENT_PORT=8742
BUILD_AGENT_RUST_VERSION=1.85
BUILD_AGENT_LUA_VERSION=5.4

