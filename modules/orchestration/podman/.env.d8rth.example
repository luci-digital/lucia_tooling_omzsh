# TrueNAS Node
HOST_IP=192.168.1.195
DEPLOYMENT_ENV=production
DEPLOYMENT_NODE=d8rth

# ZFS Storage
ZFS_POOL=tank
ZFS_BASE=/mnt/tank/luciverse

# IPv6 Addressing (2602:F674::/40)
IPV6_PREFIX=2602:F674:0001
IPV6_CROWN=2602:F674:0001:0963::1    # Judge Luci @ 963 Hz
IPV6_PAC=2602:F674:0001:0741::1      # Lucia Orchestrator @ 741 Hz
IPV6_COMN=2602:F674:0001:0639::1     # Cortana/Caddy @ 639 Hz
IPV6_CORE=2602:F674:0001:0528::1     # Veritas/SCM @ 528 Hz

# SCION Network
SCION_ISD_AS=5-528
SCION_DAEMON=/run/shm/sciond/default.sock
