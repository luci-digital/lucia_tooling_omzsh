# 🔐 Secrets (1Password injection required)
CODER_DB_PASSWORD=op://LuciVerse-PAC/Coder/db-password
CODER_PSK=op://LuciVerse-PAC/Coder/psk

# PostgreSQL (Coder backend)
POSTGRES_USER=coder
POSTGRES_PASSWORD=op://LuciVerse-PAC/Coder/db-password
