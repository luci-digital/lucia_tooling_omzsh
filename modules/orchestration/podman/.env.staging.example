# LuciDigital sovereign stack — STAGING profile template.
# Copy to `.env` and fill in real secrets. NEVER commit `.env`.
# Prefer sops-nix / agenix / 1Password for the REQUIRED secrets below.
#
# 1Password injection workflow (RECOMMENDED):
#   op inject -i .env.staging.example -o .env

LUCIVERSE_ADMIN_EMAIL=ops@staging.lucidigital.io

# REQUIRED — inject from secrets manager, do not store real values here.
# Using 1Password references (inject with: op inject -i .env.staging.example -o .env)
CODER_DB_PASSWORD=op://LuciVerse-PAC/Coder Staging/db_password
CODER_PSK=op://LuciVerse-PAC/Coder Staging/psk

CODER_ACCESS_URL=https://coder.staging.lucidigital.io
CODER_WILDCARD_ACCESS_URL=*.coder.staging.lucidigital.io

# Using 1Password references (inject with: op inject -i .env.staging.example -o .env)
GOGS_OAUTH_CLIENT_ID=op://LuciVerse-CORE/Gogs OAuth Staging/client_id
GOGS_OAUTH_CLIENT_SECRET=op://LuciVerse-CORE/Gogs OAuth Staging/client_secret

# Staging uses the same airgap-first Ollama defaults unless overridden.
ODW_CHAT_MODEL=llama3.2
ODW_ANALYSIS_MODEL=llama3.2
ODW_ENDPOINT=http://host.containers.internal:11434/v1
ODW_PROVIDER=OpenAI
# For local Ollama, keep as "ollama". For cloud providers, uncomment and use 1Password reference
ODW_API_KEY=ollama

# ── Workspace paths (optional — defaults to relative paths) ──────────────────
# These can be set if your workspace layout differs from the default structure
# LUCIA_ORCHESTRATOR_PATH=../../../luciverse-core-orchestrator
# LUCIA_COMPOSITOR_PATH=~/lucia_compositor
# LUA_SUBSTRATE_PATH=~/lua-substrate
